{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.40/schema.json",
  "app_specific_configuration_path": "$Env:KOMOREBI_CONFIG_HOME/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 8,
  "default_container_padding": 8,
  "border": true,
  "border_width": 3,
  "border_offset": 0,
  "theme": {
    "palette": "Catppuccin",
    "name": "Latte"
  },
  "animations": {
    "enabled": "true",
    "duration": 200,
    "fps": 60,
    "style": "EaseOutSine"
  },
  "monitors": [
    {
      "workspaces": [
        {
          "name": "I",
          "layout": "BSP"
        }
      ]
    }
  ]
}
